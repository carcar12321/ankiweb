generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Choice {
  A
  B
  C
  D
}

enum WrongNoteStatus {
  ACTIVE
  RESOLVED
}

enum StudySessionStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

enum ReviewRating {
  AGAIN
  HARD
  GOOD
  EASY
}

enum SchedulerAlgorithm {
  SM2
  FSRS
}

enum StudySessionMode {
  SET
  RANDOM
}

enum GeneratedQuestionDraftStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AiConversationScope {
  GENERAL
  TUTOR
  WEAKNESS
  SESSION_REPORT
  QUESTION_GENERATION
}

enum AiMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model QuestionSet {
  id                  String                   @id @default(cuid())
  title               String
  description         String?
  exportFileName      String?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  questions           Question[]
  attempts            Attempt[]
  studySessions       StudySession[]
  studySessionSources StudySessionSourceSet[]
  generatedDrafts     GeneratedQuestionDraft[]
}

model Question {
  id                String                   @id @default(cuid())
  setId             String
  prompt            String
  choiceA           String
  choiceB           String
  choiceC           String
  choiceD           String
  correct           Choice
  explanation       String
  tag               String?
  category          String?
  order             Int
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  set               QuestionSet              @relation(fields: [setId], references: [id], onDelete: Cascade)
  attempts          Attempt[]
  wrongNote         WrongNote?
  studyState        QuestionStudyState?
  reviewLogs        StudyReviewLog[]
  studySessionItems StudySessionItem[]
  generatedDrafts   GeneratedQuestionDraft[]
  aiConversations   AiConversation[]
  memos             StudyMemo[]

  @@index([setId, order])
}

model Attempt {
  id         String        @id @default(cuid())
  questionId String
  setId      String
  sessionId  String?
  selected   Choice
  isCorrect  Boolean
  answeredAt DateTime      @default(now())
  question   Question      @relation(fields: [questionId], references: [id], onDelete: Cascade)
  set        QuestionSet   @relation(fields: [setId], references: [id], onDelete: Cascade)
  session    StudySession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([questionId])
  @@index([sessionId])
  @@index([setId, answeredAt])
}

model StudySession {
  id              String                  @id @default(cuid())
  setId           String?
  mode            StudySessionMode        @default(SET)
  algorithm       SchedulerAlgorithm      @default(SM2)
  status          StudySessionStatus      @default(ACTIVE)
  currentIndex    Int                     @default(0)
  totalQuestions  Int
  correctCount    Int                     @default(0)
  startedAt       DateTime                @default(now())
  completedAt     DateTime?
  abandonedAt     DateTime?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  set             QuestionSet?            @relation(fields: [setId], references: [id], onDelete: Cascade)
  items           StudySessionItem[]
  attempts        Attempt[]
  sourceSets      StudySessionSourceSet[]
  reviewLogs      StudyReviewLog[]
  aiConversations AiConversation[]
  memos           StudyMemo[]
  aiReports       AiSessionReport[]

  @@index([setId, status, updatedAt])
  @@index([mode, status, updatedAt])
}

model StudySessionItem {
  id          String        @id @default(cuid())
  sessionId   String
  questionId  String
  position    Int
  choiceOrder String        @default("ABCD")
  selected    Choice?
  isCorrect   Boolean?
  answeredAt  DateTime?
  rating      ReviewRating?
  ratedAt     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  session     StudySession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question    Question      @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, position])
  @@index([questionId])
}

model StudySessionSourceSet {
  id        String       @id @default(cuid())
  sessionId String
  setId     String
  createdAt DateTime     @default(now())
  session   StudySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  set       QuestionSet  @relation(fields: [setId], references: [id], onDelete: Cascade)

  @@unique([sessionId, setId])
  @@index([setId])
}

model QuestionStudyState {
  id                 String             @id @default(cuid())
  questionId         String             @unique
  algorithm          SchedulerAlgorithm @default(SM2)
  dueAt              DateTime           @default(now())
  intervalDays       Int                @default(0)
  easeFactor         Float              @default(2.5)
  repetitions        Int                @default(0)
  fsrsRetrievability Float?
  fsrsStability      Float?
  fsrsDifficulty     Float?
  lastReviewedAt     DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  question           Question           @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([dueAt])
  @@index([algorithm, dueAt])
}

model StudyReviewLog {
  id                   String             @id @default(cuid())
  questionId           String
  sessionId            String?
  algorithm            SchedulerAlgorithm @default(SM2)
  rating               ReviewRating
  quality              Int
  selected             Choice
  wasCorrect           Boolean
  previousDueAt        DateTime?
  nextDueAt            DateTime
  previousIntervalDays Int
  nextIntervalDays     Int
  previousEaseFactor   Float
  nextEaseFactor       Float
  previousRepetitions  Int
  nextRepetitions      Int
  reviewedAt           DateTime           @default(now())
  question             Question           @relation(fields: [questionId], references: [id], onDelete: Cascade)
  session              StudySession?      @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([questionId, reviewedAt])
  @@index([sessionId])
  @@index([algorithm, reviewedAt])
}

model WrongNote {
  id           String          @id @default(cuid())
  questionId   String          @unique
  wrongCount   Int             @default(1)
  lastWrongAt  DateTime        @default(now())
  reviewedAt   DateTime?
  status       WrongNoteStatus @default(ACTIVE)
  dueAt        DateTime?
  intervalDays Int             @default(0)
  easeFactor   Float           @default(2.5)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  question     Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([status, lastWrongAt])
  @@index([dueAt])
}

model GeneratedQuestionDraft {
  id                 String                       @id @default(cuid())
  setId              String
  sourceQuestionId   String?
  status             GeneratedQuestionDraftStatus @default(PENDING)
  prompt             String
  choiceA            String
  choiceB            String
  choiceC            String
  choiceD            String
  correct            Choice
  explanation        String
  tag                String?
  category           String?
  rationale          String?
  approvedQuestionId String?
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt
  approvedAt         DateTime?
  set                QuestionSet                  @relation(fields: [setId], references: [id], onDelete: Cascade)
  sourceQuestion     Question?                    @relation(fields: [sourceQuestionId], references: [id], onDelete: SetNull)

  @@index([setId, status, createdAt])
  @@index([sourceQuestionId])
}

model AiSettings {
  id                 String   @id @default("default")
  model              String   @default("gpt-5.4-mini")
  reasoningEffort    String   @default("medium")
  tone               String   @default("차분하고 쉬운 한국어 학습 코치")
  customInstructions String   @default("")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model AiConversation {
  id               String              @id @default(cuid())
  scope            AiConversationScope @default(GENERAL)
  title            String
  model            String?
  sourceSessionId  String?
  sourceQuestionId String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  sourceSession    StudySession?       @relation(fields: [sourceSessionId], references: [id], onDelete: SetNull)
  sourceQuestion   Question?           @relation(fields: [sourceQuestionId], references: [id], onDelete: SetNull)
  messages         AiMessage[]
  memos            StudyMemo[]
  reports          AiSessionReport[]

  @@index([scope, updatedAt])
  @@index([sourceSessionId])
  @@index([sourceQuestionId])
}

model AiMessage {
  id             String         @id @default(cuid())
  conversationId String
  role           AiMessageRole
  content        String
  model          String?
  createdAt      DateTime       @default(now())
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model StudyMemo {
  id                   String          @id @default(cuid())
  title                String?
  content              String
  sourceText           String?
  sourceUrl            String?
  sourceSessionId      String?
  sourceQuestionId     String?
  sourceConversationId String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  sourceSession        StudySession?   @relation(fields: [sourceSessionId], references: [id], onDelete: SetNull)
  sourceQuestion       Question?       @relation(fields: [sourceQuestionId], references: [id], onDelete: SetNull)
  sourceConversation   AiConversation? @relation(fields: [sourceConversationId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([sourceSessionId])
  @@index([sourceQuestionId])
  @@index([sourceConversationId])
}

model AiSessionReport {
  id             String          @id @default(cuid())
  sessionId      String
  conversationId String?
  title          String
  content        String
  model          String?
  prompt         String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  session        StudySession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  conversation   AiConversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([sessionId, createdAt])
  @@index([conversationId])
}
